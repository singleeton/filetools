generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- AUTH ---

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("superadmin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

// --- USERS ---

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  plan      String   @default("free") // free, premium
  usageToday Int     @default(0)
  lastUsageDate DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signatures UserSignature[]

  @@map("users")
}

model UserSignature {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  pathname  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("user_signatures")
}

// --- SITE SETTINGS (CMS) ---

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
  type  String @default("string") // string, json, boolean, number

  @@map("site_settings")
}

// --- TOOL MANAGEMENT ---

model Tool {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  category    String
  icon        String
  isActive    Boolean  @default(true)
  isPremium   Boolean  @default(false)
  sortOrder   Int      @default(0)
  maxFileSize Int      @default(52428800) // 50MB
  config      String?  @db.Text // JSON string for extra config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usageLogs ToolUsageLog[]

  @@map("tools")
}

// --- ANALYTICS ---

model ToolUsageLog {
  id            String   @id @default(cuid())
  toolId        String
  tool          Tool     @relation(fields: [toolId], references: [id])
  event         String   // upload_start, conversion_start, conversion_complete, download
  fileSize      Int?
  outputSize    Int?
  duration      Int?     // ms
  locale        String?
  userAgent     String?  @db.Text
  ip            String?
  country       String?
  createdAt     DateTime @default(now())

  @@index([toolId])
  @@index([createdAt])
  @@index([event])
  @@map("tool_usage_logs")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  locale    String?
  referrer  String?  @db.Text
  userAgent String?  @db.Text
  ip        String?
  country   String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@map("page_views")
}

// --- ADS ---

model AdSlot {
  id       String  @id @default(cuid())
  name     String  @unique // header, sidebar, tool-top, tool-bottom
  label    String
  code     String? @db.Text // HTML/JS ad code
  isActive Boolean @default(false)

  @@map("ad_slots")
}

// --- LANDING PAGE CMS ---

model LandingContent {
  id       String @id @default(cuid())
  section  String // hero, features, howItWorks, faq, cta, trust
  locale   String @default("en")
  content  String @db.Text // JSON string
  sortOrder Int   @default(0)

  @@unique([section, locale])
  @@map("landing_content")
}

// --- BLOG ---

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id              String     @id @default(cuid())
  slug            String
  locale          String
  title           String
  excerpt         String     @db.Text
  content         String     @db.Text // Markdown
  coverImageUrl   String?
  status          BlogStatus @default(DRAFT)
  aiGenerated     Boolean    @default(false)
  translationKey  String?    // links same-topic posts across locales (AI batches only)
  metaTitle       String?
  metaDescription String?    @db.Text
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([slug, locale])
  @@index([locale, status, publishedAt])
  @@index([translationKey])
  @@map("blog_posts")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  pathname  String
  filename  String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("media")
}

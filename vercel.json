{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    },
    "app/api/cron/generate-blog/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cleanup-tool-outputs",
      "schedule": "0 * * * *"
    }
  ]
}

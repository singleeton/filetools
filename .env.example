# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=FileTools

# Database (Neon free tier: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin Auth
ADMIN_JWT_SECRET=generate-a-random-64-char-string
ADMIN_SEED_SECRET=generate-another-random-string

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Blog AI (Google Gemini — free tier via https://aistudio.google.com/apikey, no billing required)
GEMINI_API_KEY=
# Blog AI (OpenAI — alternative provider, only needed if ACTIVE_PROVIDER in src/lib/blog-ai/service.ts is set to 'openai')
# OPENAI_API_KEY=

# Vercel Blob (auto-provided when a Blob store is linked in the Vercel dashboard)
BLOB_READ_WRITE_TOKEN=

# Cron auth (Vercel sends this automatically as a Bearer token for its own cron invocations)
CRON_SECRET=

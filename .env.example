# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=FileTools

# Database (Neon free tier: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin Auth
ADMIN_JWT_SECRET=generate-a-random-64-char-string
ADMIN_SEED_SECRET=generate-another-random-string

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Storage (Post-MVP)
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=
